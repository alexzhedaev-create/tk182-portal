# PostgreSQL
POSTGRES_DB=tk182_portal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# API
API_HOST=127.0.0.1
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/tk182_portal
SESSION_COOKIE_NAME=tk182_session
SESSION_TTL_HOURS=168
SESSION_COOKIE_SECURE=false
FILE_STORAGE_DIR=storage/uploads
FILE_STORAGE_MAX_BYTES=10485760
FILE_STORAGE_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.xlsx,.zip,.txt

# Web
WEB_HOST=127.0.0.1
WEB_PORT=3000
WEB_PUBLIC_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
API_INTERNAL_URL=http://127.0.0.1:3001
NEXT_PUBLIC_APP_NAME=Портал ТК 182
